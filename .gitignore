# Ignore everything by default
/*

# Except these specific files/directories
!/public/docs/exemplaires-import-biens/
!/import_prospects*

# Keep the directory structure
!/public/
!/public/docs/

# Ignore all other files and directories
/.phpunit.cache
/node_modules
/public/build
/public/img
/public/files
/public/hot
/public/storage
/storage/*.key
/vendor
.env*.local
/.env
/.env.backup
/.env.production
/.env.aws
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log
/.fleet
/.idea
/.vscode
**uploads

nginx/ssl/

*.swp
*.swo

# Allow Passport keys
!storage/oauth-private.key
!storage/oauth-public.key

# Deployment scripts with credentials
deploy-wrapper.sh
get-api-url.sh
aws-deploy-ecs.sh
dev.sh
prod.sh
scheduler.sh
docker-compose.dev.yml
docker-compose.prod.yml

# Re-ignore everything else in public/Docs except the specific folder
/public/docs/*
!/public/docs/exemplaires-import-biens/
